    ValueLabel.TextColor3 = Color3.fromRGB(255, 255, 255); ValueLabel.Font = Enum.Font.GothamBold; ValueLabel.TextSize = 15; ValueLabel.TextXAlignment = Enum.TextXAlignment.Right; ValueLabel.BackgroundTransparency = 1
    local Base = Instance.new("Frame", Container)
    Base.Size = UDim2.new(1, 0, 0, 3); Base.Position = UDim2.new(0, 0, 0, 38); Base.BackgroundColor3 = Color3.fromRGB(30, 40, 55); Base.BorderSizePixel = 0
    local Fill = Instance.new("Frame", Base)
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0); Fill.BackgroundColor3 = Color3.fromRGB(59, 130, 246); Fill.BorderSizePixel = 0
    local Knob = Instance.new("Frame", Fill)
    Knob.Size = UDim2.new(0, 14, 0, 14); Knob.Position = UDim2.new(1, -7, 0.5, -7); Knob.BackgroundColor3 = Color3.fromRGB(59, 130, 246)
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    local function update(input)
        local pos = math.clamp((input.Position.X - Base.AbsolutePosition.X) / Base.AbsoluteSize.X, 0, 1)
        Fill.Size = UDim2.new(pos, 0, 1, 0)
        local val = math.floor(min + (max - min) * pos)
        ValueLabel.Text = tostring(val)
        callback(val)
    end
    Base.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end end)
end

