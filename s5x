-- Render Logic (STABILIZED)
RunService.RenderStepped:Connect(function()
    -- 1. AIMBOT FIRST (Important for ESP stability)
    local isHoldDown = false
    if Settings.HoldKey then
        if Settings.HoldKey.EnumType == Enum.KeyCode then
            isHoldDown = UserInputService:IsKeyDown(Settings.HoldKey)
        else
            isHoldDown = UserInputService:IsMouseButtonPressed(Settings.HoldKey)
        end
    end

    if Settings.AimbotEnabled and (Settings.ToggleMode or isHoldDown) then
    local targetPlayer = GetClosest()

    if targetPlayer
    and targetPlayer.Character
    and targetPlayer.Character:FindFirstChild(Settings.AimPart) then

        local targetPart =
            targetPlayer.Character[Settings.AimPart]

        local targetPos = targetPart.Position

        if Settings.PredictionEnabled then
            targetPos =
                targetPos +
                (targetPart.Velocity * Settings.PredictionAmount)
        end

        local screenPos =
            Camera:WorldToViewportPoint(targetPos)

        local mousePos =
            UserInputService:GetMouseLocation()

        mousemoverel(
            (screenPos.X - mousePos.X) /
                Settings.Smoothness,

            (screenPos.Y - mousePos.Y) /
                Settings.Smoothness
        )
    end
end

    -- 2. DRAWING ELEMENTS (Uses updated Camera CFrame)
    local Center = Settings.UseMousePos and UserInputService:GetMouseLocation() or Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    FOVCircle.Visible = Settings.ShowFOVCircle
    FOVCircle.Radius = Settings.FOVSize
    FOVCircle.Position = Center

    -- Spinning Crosshair Logic
    if Settings.ShowCrosshair then
        local rotation = tick() * 12
        local length = 9
        local gap = 3
        
        for i = 1, 4 do
            local line = CrosshairLines[i]
            local outline = CrosshairOutlines[i]
            
            line.Visible = true
            outline.Visible = true
            
            local angle = math.rad((i-1) * 90) + rotation
            local cos, sin = math.cos(angle), math.sin(angle)
            
            local startPos = Center + Vector2.new(cos * gap, sin * gap)
            local endPos = Center + Vector2.new(cos * (gap + length), sin * (gap + length))
            
            line.From = startPos
            line.To = endPos
            outline.From = startPos
            outline.To = endPos
        end
    else
        for i = 1, 4 do
            CrosshairLines[i].Visible = false
            CrosshairOutlines[i].Visible = false
        end
    end

    -- 3. ESP RENDERING (Now stable because Camera updated first)
    for player, esp in pairs(ESPTable) do
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")

        if Settings.ESPEnabled and char and hum and hrp and hum.Health > 0 then
            local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
            
            if dist < Settings.ESPDistance then
                if Settings.TeamCheck and player.Team == LocalPlayer.Team then
                    for _, v in pairs(esp) do v.Visible = false end
                    continue
                end

                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local head = char:FindFirstChild("Head")
                    local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                    local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                    local height = math.abs(headPos.Y - legPos.Y)
                    local width = height / 2

                    esp.Box.Size = Vector2.new(width, height)
                    esp.Box.Position = Vector2.new(pos.X - width/2, pos.Y - height/2)
                    esp.Box.Visible = true

                    esp.HealthBar.From = Vector2.new(pos.X - width/2 - 5, pos.Y + height/2)
                    esp.HealthBar.To = Vector2.new(pos.X - width/2 - 5, (pos.Y + height/2) - (height * (hum.Health / hum.MaxHealth)))
                    esp.HealthBar.Visible = true

                    esp.Name.Text = player.Name
                    esp.Name.Position = Vector2.new(pos.X, pos.Y - height/2 - 15)
                    esp.Name.Visible = true

                    esp.Distance.Text = math.floor(dist) .. "m"
                    esp.Distance.Position = Vector2.new(pos.X, pos.Y + height/2 + 5)
                    esp.Distance.Visible = true
                else
                    for _, v in pairs(esp) do v.Visible = false end
                end
            else
                for _, v in pairs(esp) do v.Visible = false end
            end
        else
            for _, v in pairs(esp) do v.Visible = false end
        end
    end
end)

-- Dragging & Input Logic
local dragging, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

SevenBtn.MouseButton1Click:Connect(function()
    SevenBtn.Text = "..."
    local conn; conn = UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            Settings.HideKey = input.KeyCode
            SevenBtn.Text = input.KeyCode.Name
            conn:Disconnect()
        end
    end)
end)
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Settings.HideKey then
        Settings.MenuVisible = not Settings.MenuVisible
        MainFrame.Visible = Settings.MenuVisible
    end
    if Settings.AimbotToggleKey and input.KeyCode == Settings.AimbotToggleKey then
        Settings.AimbotEnabled = not Settings.AimbotEnabled
        if AimbotToggleUI.Update then AimbotToggleUI.Update(Settings.AimbotEnabled) end
        StatusDot.BackgroundColor3 = Settings.AimbotEnabled and Color3.fromRGB(59, 130, 246) or Color3.fromRGB(60, 65, 75)
        StatusText.Text = Settings.AimbotEnabled and "active" or "idle"
    end
end)
